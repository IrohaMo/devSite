---
interface Props {
    href: string;
    title?: string;
}

const { href, title = 'Post on X' } = Astro.props;
---

<div class="x-embed">
    <blockquote class="twitter-tweet" data-theme="dark" data-dnt="true" data-conversation="none">
        <a href={href}>{title}</a>
    </blockquote>
</div>

<script is:inline>
    const loadXWidget = () => {
        if (window.twttr?.widgets?.load) {
            window.twttr.widgets.load();
            return;
        }

        if (document.querySelector('script[src="https://platform.twitter.com/widgets.js"]')) {
            return;
        }

        const script = document.createElement('script');
        script.src = 'https://platform.twitter.com/widgets.js';
        script.async = true;
        script.charset = 'utf-8';
        script.onload = () => window.twttr?.widgets?.load?.();
        document.head.appendChild(script);
    };

    loadXWidget();

    document.addEventListener('astro:page-load', loadXWidget);
</script>

<style>
    .x-embed {
        display: flex;
        justify-content: center;
        width: 100%;
        overflow: hidden;
    }

    .x-embed :global(iframe),
    .x-embed :global(.twitter-tweet) {
        width: 100% !important;
        max-width: 35rem !important;
    }

    .x-embed :global(blockquote.twitter-tweet) {
        padding: 0 !important;
        border: 0 !important;
        font-family: var(--font-body) !important;
        font-size: var(--text-base) !important;
        font-weight: 400 !important;
        line-height: 1.5 !important;
        color: var(--gray-200) !important;
    }

    .x-embed a {
        color: var(--gray-300);
        font-size: var(--text-md);
    }

    .x-embed :global(.twitter-tweet) {
        margin: 0 !important;
    }
    
    .x-embed {
        display: flex;
        justify-content: center;
        width: 100%;
        
        border-radius: 1.5rem;
        overflow: hidden;
    }

    .x-embed :global(iframe) {
        border-radius: 1.5rem !important;
        display: block;
    }
    
    
</style>
